{
  "name": "sjquakesbot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Mod bot for r/SJEarthquakes: posts news articles and match threads, manages flairs, and handles scheduling.",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "login": "devvit login",
    "playtest": "devvit playtest",
    "upload": "devvit upload"
  },
  "dependencies": {
    "@devvit/public-api": "^0.13.5",
    "@devvit/web": "^0.13.5",
    "@hono/node-server": "1.19.14",
    "cheerio": "1.2.0",
    "hono": "4.12.27"
  },
  "devDependencies": {
    "@devvit/start": "^0.13.5",
    "@devvit/test": "^0.13.5",
    "@types/node": "22.18.0",
    "@vitest/coverage-v8": "^4.1.0",
    "devvit": "^0.13.5",
    "typescript": "5.8.3",
    "vite": "8.1.0",
    "vitest": "^4.1.0"
  },
  "license": "BSD-3-Clause"
}
